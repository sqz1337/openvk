SELECT COUNT(id) AS cnt FROM
(
  (
    SELECT
      recipient_id AS id
    FROM messages
    WHERE
      sender_id = ?
    AND
      sender_type = ?
    AND
      conversation_id IS NULL
  ) UNION (
    SELECT
      sender_id AS id
    FROM messages
    WHERE
      recipient_id = ?
    AND
      recipient_type = ?
    AND
      conversation_id IS NULL
  )
) dt
